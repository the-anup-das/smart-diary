# Database Configuration
DATABASE_URL="postgresql://diary_user:diary_password@localhost:5432/diary_db?schema=public"
JWT_SECRET=super-secret-diary-key-you-should-change

# LLM Configuration
OPENAI_API_KEY="sk-proj-..."
OPENAI_BASE_URL="https://api.openai.com/v1"

# STT (Speech-to-Text) Configuration
# Point to any OpenAI-compatible /v1/audio/transcriptions endpoint.
# Examples:
#   LM Studio on your machine : http://host.docker.internal:1234/v1
#   OpenAI API                : https://api.openai.com/v1
#   Any local Whisper server  : http://<ip>:<port>/v1
STT_BASE_URL="http://host.docker.internal:1234/v1"
STT_API_KEY="lm-studio"
STT_MODEL="whisper-1"

# PWA Controls
# Set to 'true' to disable PWA entirely (even in production)
PWA_DISABLED=false
# Set to 'true' to force enable PWA/Service Worker during local development
LOCAL_FORCE_PWA_ENABLE=false
