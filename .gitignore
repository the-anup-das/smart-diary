# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================================
# SECRETS — never commit these
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/

# ============================================================
# Python
# ============================================================
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ============================================================
# Node / Next.js
# ============================================================
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ============================================================
# Testing & coverage
# ============================================================
/coverage

# ============================================================
# Docker
# ============================================================
.dockerignore
docker-compose.override.yml

# ============================================================
# Databases & generated files
# ============================================================
*.sqlite
*.sqlite3
*.db
/src/generated/prisma

# ============================================================
# Logs & debug
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# ============================================================
# OS junk
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================
